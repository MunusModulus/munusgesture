{
  "manifest_version": 3,
  "name": "__MSG_chrome_extension_name__",
  "version": "1.5.5",
  "description": "__MSG_chrome_extension_description__",

  "background": {
    "service_worker": "js/background.js"
  },

  "content_scripts": [
    {
      "js": ["js/config.js", "js/x.js", "js/tween2.js", "js/chrome_gestures.js"],
      "matches": ["http://*/*", "https://*/*"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "default_locale": "en_US",

  "icons": {
    "128": "gm_icon_128.png",
    "16": "gm_icon_16.png",
    "32": "gm_icon_32.png",
    "64": "gm_icon_64.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["up.png", "right.png", "left.png", "down.png"],
      "matches": ["<all_urls>"]
    }
  ],

  "permissions": ["tabs", "storage", "scripting", "clipboardWrite", "downloads"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "options_page": "options_page.html"
}
